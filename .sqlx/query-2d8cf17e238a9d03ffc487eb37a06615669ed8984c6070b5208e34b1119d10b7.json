  "query": "\n            SELECT\n                s.id as session_id,\n                s.weight as relative_priority,\n                s.min_factor,\n                s.max_factor,\n                s.is_ready\n            FROM session s\n            WHERE s.reservation_id = $1\n            AND s.deleted_at IS NULL\n            ORDER BY s.name DESC\n            ",
